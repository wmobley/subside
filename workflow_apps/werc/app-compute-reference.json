{
  "id": "subside-werc-compute-reference",
  "version": "0.1.0",
  "description": "WERC stage 2: pick a reference (auto or manual) and subtract its offset from the displacement stack.",
  "owner": "${apiUserId}",
  "enabled": true,
  "runtime": "SINGULARITY",
  "runtimeVersion": null,
  "runtimeOptions": ["SINGULARITY_RUN"],
  "containerImage": "docker://ghcr.io/wmobley/subside-werc-opera-analysis:0.1.0",
  "jobType": "BATCH",
  "maxJobs": -1,
  "maxJobsPerUser": -1,
  "strictFileInputs": false,
  "jobAttributes": {
    "description": null,
    "dynamicExecSystem": false,
    "execSystemConstraints": null,
    "execSystemId": "ls6",
    "execSystemExecDir": "${JobWorkingDir}",
    "execSystemInputDir": "${JobWorkingDir}",
    "execSystemOutputDir": "${JobWorkingDir}/output",
    "execSystemLogicalQueue": "vm-small",
    "archiveSystemId": "cloud.data",
    "archiveSystemDir": "HOST_EVAL($HOME)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
    "archiveOnAppError": true,
    "isMpi": false,
    "mpiCmd": null,
    "cmdPrefix": "mkdir -p $PWD/output $PWD/output/anchors $PWD/inputs;",
    "parameterSet": {
      "appArgs": [
        {"name": "stack flag", "inputMode": "FIXED", "arg": "--stack", "notes": {"isHidden": true}},
        {"name": "Input stack path", "inputMode": "FIXED", "arg": "inputs/displacement_stack.nc"},
        {"name": "output-stack flag", "inputMode": "FIXED", "arg": "--output-stack", "notes": {"isHidden": true}},
        {"name": "Output stack path", "inputMode": "FIXED", "arg": "output/displacement_stack_referenced.nc"},
        {"name": "output-summary flag", "inputMode": "FIXED", "arg": "--output-summary", "notes": {"isHidden": true}},
        {"name": "Output summary path", "inputMode": "FIXED", "arg": "output/reference_summary.json"},
        {"name": "mode flag", "inputMode": "FIXED", "arg": "--mode", "notes": {"isHidden": true}},
        {"name": "Reference mode", "inputMode": "INCLUDE_ON_DEMAND", "arg": "auto", "description": "auto | manual | none"},
        {"name": "anchor-dir flag", "inputMode": "FIXED", "arg": "--anchor-dir", "notes": {"isHidden": true}},
        {"name": "Anchor directory", "inputMode": "FIXED", "arg": "output/anchors"}
      ],
      "schedulerOptions": [
        {"name": "TACC Scheduler Profile", "inputMode": "FIXED", "arg": "--tapis-profile tacc-apptainer", "notes": {"isHidden": true}},
        {"name": "TACC Allocation", "inputMode": "INCLUDE_ON_DEMAND", "arg": null, "notes": {"isHidden": true}}
      ],
      "envVariables": [
        {"key": "STAGE", "value": "compute-reference", "inputMode": "FIXED"},
        {"key": "UPDATE_CONDA_ENV", "value": "false", "inputMode": "INCLUDE_ON_DEMAND"}
      ],
      "archiveFilter": {"includes": [], "excludes": [], "includeLaunchFiles": true}
    },
    "fileInputs": [
      {"name": "stack-input", "inputMode": "REQUIRED", "autoMountLocal": false, "sourceUrl": null, "targetPath": "inputs/displacement_stack.nc", "description": "displacement_stack.nc produced by build-stack."},
      {"name": "anchor-history", "inputMode": "OPTIONAL", "autoMountLocal": false, "sourceUrl": null, "targetPath": "output/anchors", "description": "Optional pre-existing anchor JSONs to preserve per-frame reference reproducibility."}
    ],
    "fileInputArrays": [],
    "nodeCount": 1,
    "coresPerNode": 8,
    "memoryMB": 32000,
    "maxMinutes": 60,
    "subscriptions": [],
    "tags": []
  },
  "tags": ["portalName: ALL", "subside", "opera-disp-s1", "werc", "workflow-task"],
  "notes": {
    "label": "SUBSIDE WERC Compute Reference",
    "hideNodeCountAndCoresPerNode": true,
    "isInteractive": false,
    "icon": "satellite",
    "category": "Data Processing",
    "queueFilter": ["vm-small", "development"]
  }
}
