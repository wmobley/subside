{
  "id": "subside-werc-export-geotiffs",
  "version": "0.1.0",
  "description": "WERC stage 4: reproject + write cumulative displacement and velocity GeoTIFFs (EPSG:4326, mm units).",
  "owner": "${apiUserId}",
  "enabled": true,
  "runtime": "SINGULARITY",
  "runtimeVersion": null,
  "runtimeOptions": ["SINGULARITY_RUN"],
  "containerImage": "docker://ghcr.io/wmobley/subside-werc-opera-analysis:0.1.0",
  "jobType": "BATCH",
  "maxJobs": -1,
  "maxJobsPerUser": -1,
  "strictFileInputs": false,
  "jobAttributes": {
    "description": null,
    "dynamicExecSystem": false,
    "execSystemConstraints": null,
    "execSystemId": "ls6",
    "execSystemExecDir": "${JobWorkingDir}",
    "execSystemInputDir": "${JobWorkingDir}",
    "execSystemOutputDir": "${JobWorkingDir}/output",
    "execSystemLogicalQueue": "vm-small",
    "archiveSystemId": "cloud.data",
    "archiveSystemDir": "HOST_EVAL($HOME)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
    "archiveOnAppError": true,
    "isMpi": false,
    "mpiCmd": null,
    "cmdPrefix": "mkdir -p $PWD/output $PWD/inputs;",
    "parameterSet": {
      "appArgs": [
        {"name": "stack flag", "inputMode": "FIXED", "arg": "--stack", "notes": {"isHidden": true}},
        {"name": "Input stack path", "inputMode": "FIXED", "arg": "inputs/displacement_stack_referenced.nc"},
        {"name": "velocity flag", "inputMode": "FIXED", "arg": "--velocity", "notes": {"isHidden": true}},
        {"name": "Input velocity path", "inputMode": "FIXED", "arg": "inputs/velocity.nc"},
        {"name": "output-dir flag", "inputMode": "FIXED", "arg": "--output-dir", "notes": {"isHidden": true}},
        {"name": "Output directory", "inputMode": "FIXED", "arg": "output"},
        {"name": "reference-summary flag", "inputMode": "FIXED", "arg": "--reference-summary", "notes": {"isHidden": true}},
        {"name": "Reference summary path", "inputMode": "FIXED", "arg": "inputs/reference_summary.json"}
      ],
      "schedulerOptions": [
        {"name": "TACC Scheduler Profile", "inputMode": "FIXED", "arg": "--tapis-profile tacc-apptainer", "notes": {"isHidden": true}},
        {"name": "TACC Allocation", "inputMode": "INCLUDE_ON_DEMAND", "arg": null, "notes": {"isHidden": true}}
      ],
      "envVariables": [
        {"key": "STAGE", "value": "export-geotiffs", "inputMode": "FIXED"},
        {"key": "UPDATE_CONDA_ENV", "value": "false", "inputMode": "INCLUDE_ON_DEMAND"}
      ],
      "archiveFilter": {"includes": [], "excludes": [], "includeLaunchFiles": true}
    },
    "fileInputs": [
      {"name": "stack-input", "inputMode": "REQUIRED", "autoMountLocal": false, "sourceUrl": null, "targetPath": "inputs/displacement_stack_referenced.nc"},
      {"name": "velocity-input", "inputMode": "REQUIRED", "autoMountLocal": false, "sourceUrl": null, "targetPath": "inputs/velocity.nc"},
      {"name": "reference-summary", "inputMode": "OPTIONAL", "autoMountLocal": false, "sourceUrl": null, "targetPath": "inputs/reference_summary.json"}
    ],
    "fileInputArrays": [],
    "nodeCount": 1,
    "coresPerNode": 4,
    "memoryMB": 16000,
    "maxMinutes": 30,
    "subscriptions": [],
    "tags": []
  },
  "tags": ["portalName: ALL", "subside", "opera-disp-s1", "werc", "workflow-task"],
  "notes": {
    "label": "SUBSIDE WERC Export GeoTIFFs",
    "hideNodeCountAndCoresPerNode": true,
    "isInteractive": false,
    "icon": "satellite",
    "category": "Data Processing",
    "queueFilter": ["vm-small", "development"]
  }
}
