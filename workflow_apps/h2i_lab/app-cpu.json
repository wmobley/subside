{
  "id": "subside-h2i-opera-analysis",
  "version": "0.1.0",
  "description": "Run the SUBSIDE H2I Lab OPERA DISP-S1 download/subset/preview analysis as a batch job.",
  "owner": "${apiUserId}",
  "enabled": true,
  "runtime": "SINGULARITY",
  "runtimeVersion": null,
  "runtimeOptions": [
    "SINGULARITY_RUN"
  ],
  "containerImage": "docker://ghcr.io/wmobley/subside-h2i-opera-analysis:sha-d791fa0",
  "jobType": "BATCH",
  "maxJobs": -1,
  "maxJobsPerUser": -1,
  "strictFileInputs": false,
  "jobAttributes": {
    "description": null,
    "dynamicExecSystem": false,
    "execSystemConstraints": null,
    "execSystemId": "ls6",
    "execSystemExecDir": "${JobWorkingDir}",
    "execSystemInputDir": "${JobWorkingDir}",
    "execSystemOutputDir": "${JobWorkingDir}/output",
    "execSystemLogicalQueue": "vm-small",
    "archiveSystemId": "cloud.data",
    "archiveSystemDir": "HOST_EVAL($HOME)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
    "archiveOnAppError": true,
    "isMpi": false,
    "mpiCmd": null,
    "cmdPrefix": "mkdir -p $PWD/output $PWD/config;",
    "parameterSet": {
      "appArgs": [
        {
          "name": "Run config path",
          "description": "Path to the staged SUBSIDE H2I run config JSON.",
          "inputMode": "FIXED",
          "arg": "config/run-config.json",
          "notes": {
            "isHidden": true
          }
        },
        {
          "name": "Output directory",
          "description": "Directory where the app writes manifest and artifacts.",
          "inputMode": "FIXED",
          "arg": "output",
          "notes": {
            "isHidden": true
          }
        }
      ],
      "schedulerOptions": [
        {
          "name": "TACC Scheduler Profile",
          "description": "Scheduler profile for HPC clusters at TACC.",
          "inputMode": "FIXED",
          "arg": "--tapis-profile tacc-apptainer",
          "notes": {
            "isHidden": true
          }
        },
        {
          "name": "TACC Allocation",
          "description": "TACC allocation charged for SUBSIDE analysis jobs.",
          "inputMode": "INCLUDE_ON_DEMAND",
          "arg": null,
          "notes": {
            "isHidden": true
          }
        }
      ],
      "envVariables": [
        {
          "key": "UPDATE_CONDA_ENV",
          "value": "false",
          "description": "Set to 'true' to force run.sh to delete and recreate the conda environment under $WORK before running the analysis. Useful after bumping environment.yaml.",
          "inputMode": "INCLUDE_ON_DEMAND"
        }
      ],
      "archiveFilter": {
        "includes": [],
        "excludes": [],
        "includeLaunchFiles": true
      }
    },
    "fileInputs": [
      {
        "name": "run-config",
        "description": "SUBSIDE H2I run configuration JSON.",
        "inputMode": "REQUIRED",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "config/run-config.json"
      },
      {
        "name": "aoi-geojson",
        "description": "Optional AOI GeoJSON used by the run config.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": "config/aoi.geojson"
      },
      {
        "name": "earthdata-netrc",
        "description": "Optional protected Earthdata .netrc file. Prefer Tapis secrets before production registration.",
        "inputMode": "OPTIONAL",
        "autoMountLocal": true,
        "sourceUrl": null,
        "targetPath": ".netrc"
      }
    ],
    "fileInputArrays": [],
    "nodeCount": 1,
    "coresPerNode": 16,
    "memoryMB": 128000,
    "maxMinutes": 240,
    "subscriptions": [],
    "tags": []
  },
  "tags": [
    "portalName: ALL",
    "subside",
    "opera-disp-s1",
    "h2i-lab"
  ],
  "notes": {
    "label": "SUBSIDE H2I OPERA Analysis",
    "hideNodeCountAndCoresPerNode": true,
    "isInteractive": false,
    "icon": "satellite",
    "category": "Data Processing",
    "queueFilter": [
      "vm-small",
      "development"
    ]
  }
}
