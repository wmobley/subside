{
  "id": "subside-h2i-discover",
  "version": "0.1.0",
  "description": "SUBSIDE preflight: OPERA DISP-S1 frame + product discovery for an AOI/date range (no NetCDF download).",
  "owner": "${apiUserId}",
  "enabled": true,
  "runtime": "SINGULARITY",
  "runtimeVersion": null,
  "runtimeOptions": ["SINGULARITY_RUN"],
  "containerImage": "docker://ghcr.io/wmobley/subside-h2i-opera-analysis:0.1.0",
  "jobType": "BATCH",
  "maxJobs": -1,
  "maxJobsPerUser": -1,
  "strictFileInputs": false,
  "jobAttributes": {
    "description": null,
    "dynamicExecSystem": false,
    "execSystemConstraints": null,
    "execSystemId": "ls6",
    "execSystemExecDir": "${JobWorkingDir}",
    "execSystemInputDir": "${JobWorkingDir}",
    "execSystemOutputDir": "${JobWorkingDir}/output",
    "execSystemLogicalQueue": "vm-small",
    "archiveSystemId": "cloud.data",
    "archiveSystemDir": "HOST_EVAL($HOME)/tapis-jobs-archive/${JobCreateDate}/${JobName}-${JobUUID}",
    "archiveOnAppError": true,
    "isMpi": false,
    "mpiCmd": null,
    "cmdPrefix": "mkdir -p $PWD/output $PWD/config;",
    "parameterSet": {
      "appArgs": [
        {"name": "Run config path", "inputMode": "FIXED", "arg": "config/run-config.json", "notes": {"isHidden": true}},
        {"name": "Output directory", "inputMode": "FIXED", "arg": "output", "notes": {"isHidden": true}}
      ],
      "schedulerOptions": [
        {"name": "TACC Scheduler Profile", "inputMode": "FIXED", "arg": "--tapis-profile tacc-apptainer", "notes": {"isHidden": true}},
        {"name": "TACC Allocation", "inputMode": "INCLUDE_ON_DEMAND", "arg": null, "notes": {"isHidden": true}}
      ],
      "envVariables": [
        {"key": "STAGE", "value": "preflight", "description": "Dispatches run.sh to the discover-only CLI subcommand.", "inputMode": "FIXED"},
        {"key": "UPDATE_CONDA_ENV", "value": "false", "description": "Force rebuild of the runtime conda env.", "inputMode": "INCLUDE_ON_DEMAND"}
      ],
      "archiveFilter": {"includes": [], "excludes": [], "includeLaunchFiles": true}
    },
    "fileInputs": [
      {"name": "run-config", "inputMode": "REQUIRED", "autoMountLocal": true, "sourceUrl": null, "targetPath": "config/run-config.json"},
      {"name": "aoi-geojson", "inputMode": "OPTIONAL", "autoMountLocal": true, "sourceUrl": null, "targetPath": "config/aoi.geojson"},
      {"name": "earthdata-netrc", "inputMode": "OPTIONAL", "autoMountLocal": true, "sourceUrl": null, "targetPath": ".netrc"}
    ],
    "fileInputArrays": [],
    "nodeCount": 1,
    "coresPerNode": 2,
    "memoryMB": 8000,
    "maxMinutes": 30,
    "subscriptions": [],
    "tags": []
  },
  "tags": ["portalName: ALL", "subside", "opera-disp-s1", "h2i-lab", "workflow-task"],
  "notes": {
    "label": "SUBSIDE H2I OPERA Discover",
    "hideNodeCountAndCoresPerNode": true,
    "isInteractive": false,
    "icon": "satellite",
    "category": "Data Processing",
    "queueFilter": ["vm-small", "development"]
  }
}
